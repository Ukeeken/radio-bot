<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Black Sheep Radio</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0f0f0f;
    color: white;
    text-align: center;
}

/* HEADER */
.header {
    padding: 20px;
    background: #111;
    border-bottom: 2px solid #ff0033;
}

.logo {
    font-size: 26px;
    font-weight: bold;
    color: #ff0033;
}

/* PLAYER SECTION */
.player {
    padding: 30px;
}

.onair {
    color: #ff0033;
    font-weight: bold;
    margin-bottom: 10px;
}

.song {
    font-size: 22px;
    margin: 10px 0;
}

.artist {
    font-size: 18px;
    opacity: 0.8;
}

.dj {
    margin-top: 10px;
    font-size: 16px;
    color: #aaa;
}

/* BUTTONS */
.buttons {
    margin-top: 25px;
}

button {
    background: #ff0033;
    border: none;
    padding: 12px 20px;
    margin: 5px;
    color: white;
    font-size: 16px;
    cursor: pointer;
    border-radius: 6px;
}

button:hover {
    opacity: 0.85;
}

/* DJ STATUS */
.status {
    margin-top: 15px;
    font-size: 14px;
    color: #aaa;
}

/* LIVE INDICATOR */
.live-dot {
    height: 10px;
    width: 10px;
    background: red;
    border-radius: 50%;
    display: inline-block;
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
}

/* FOOTER */
.footer {
    margin-top: 40px;
    font-size: 12px;
    color: #666;
}
</style>
</head>

<body>

<div class="header">
    <div class="logo">🎧 Black Sheep Radio</div>
</div>

<div class="player">

    <div class="onair">
        🔴 ON AIR <span class="live-dot"></span>
    </div>

    <div class="song" id="song">Loading song...</div>
    <div class="artist" id="artist">Loading artist...</div>

    <div class="dj">
        🎙 DJ: <span id="dj">Offline</span>
    </div>

    <div class="status" id="status">
        Connecting to server...
    </div>

    <div class="buttons">
        <button onclick="openStream()">▶ Listen Live</button>
        <button onclick="openRequest()">🎵 Request Song</button>
    </div>

</div>

<div class="footer">
    Live365 Stream • Black Sheep Radio
</div>

<script>
const API_URL = "/now-playing";   // YOU will add this endpoint in Flask

function openStream() {
    window.open("https://streaming.live365.com/a97529", "_blank");
}

function openRequest() {
    window.open("/", "_blank"); // your Flask request page
}

/* LIVE UPDATES */
async function updatePlayer() {
    try {
        const res = await fetch(API_URL);
        const data = await res.json();

        document.getElementById("song").innerText =
            "🎵 " + (data.title || "Unknown");

        document.getElementById("artist").innerText =
            "👤 " + (data.artist || "Unknown");

        document.getElementById("dj").innerText =
            data.dj || "Offline";

        document.getElementById("status").innerText =
            "🟢 Live";

    } catch (e) {
        document.getElementById("status").innerText =
            "🔴 Disconnected";
    }
}

setInterval(updatePlayer, 5000);
updatePlayer();
</script>

</body>
</html>